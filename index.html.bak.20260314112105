<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>奥小秘 · AI 助手</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #08090c;
  --bg2: #0f1117;
  --border: rgba(255,255,255,0.06);
  --text: #e8eaf0;
  --muted: #5a6070;
  --accent: #FF9900;
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Inter', -apple-system, 'PingFang SC', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── HERO ── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 24px;
  text-align: center;
}
.hero::after {
  content: '';
  position: absolute;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(255,153,0,0.07) 0%, transparent 70%);
  top: 50%; left: 50%;
  transform: translate(-50%, -60%);
  pointer-events: none;
}

.avatar-wrap {
  position: relative;
  width: 88px; height: 88px;
  margin: 0 auto 32px;
}
.avatar {
  width: 88px; height: 88px;
  border-radius: 50%;
  background: linear-gradient(135deg, #1a1c24, #232630);
  border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 40px;
  position: relative; z-index: 1;
}
.avatar-ring {
  position: absolute; inset: -4px;
  border-radius: 50%;
  background: conic-gradient(from 180deg, #FF9900, #FFD060, transparent, transparent);
  animation: spin 6s linear infinite;
  z-index: 0;
}
.avatar-ring::before {
  content: ''; position: absolute; inset: 2px;
  border-radius: 50%; background: var(--bg);
}
@keyframes spin { to { transform: rotate(360deg); } }

.badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(255,153,0,0.08);
  border: 1px solid rgba(255,153,0,0.18);
  color: #FF9900; font-size: 11px; font-weight: 600;
  letter-spacing: 1.2px; text-transform: uppercase;
  padding: 5px 14px; border-radius: 20px; margin-bottom: 24px;
}
.badge-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #FF9900; animation: blink 2s ease-in-out infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

.hero h1 {
  font-size: clamp(36px, 8vw, 64px);
  font-weight: 700; letter-spacing: -1.5px;
  line-height: 1.1; margin-bottom: 16px;
}
.hero h1 span {
  background: linear-gradient(135deg, #FF9900 0%, #FFD060 60%, #FF9900 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-size: 200% auto; animation: shine 4s linear infinite;
}
@keyframes shine { to { background-position: 200% center; } }

.hero-desc {
  font-size: clamp(15px, 2.5vw, 18px);
  color: var(--muted); max-width: 460px;
  line-height: 1.7; margin-bottom: 48px; font-weight: 300;
}

.hero-tags {
  display: flex; gap: 10px; flex-wrap: wrap;
  justify-content: center; margin-bottom: 56px;
}
.tag {
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border);
  color: #8892a4; font-size: 13px;
  padding: 7px 16px; border-radius: 20px; transition: all 0.2s;
}
.tag:hover { border-color: rgba(255,153,0,0.3); color: #FF9900; background: rgba(255,153,0,0.05); }

.scroll-hint {
  position: absolute; bottom: 36px;
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  color: var(--muted); font-size: 11px; letter-spacing: 1px; text-transform: uppercase;
  animation: float 2.5s ease-in-out infinite;
}
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(6px)} }
.scroll-arrow {
  width: 20px; height: 20px;
  border-right: 1.5px solid var(--muted);
  border-bottom: 1.5px solid var(--muted);
  transform: rotate(45deg);
}

/* ── SECTION ── */
.section { max-width: 800px; margin: 0 auto; padding: 80px 24px; }

.line-title { display: flex; align-items: center; gap: 14px; margin-bottom: 40px; }
.line-title::before { content: ''; width: 32px; height: 1px; background: var(--accent); flex-shrink: 0; }
.line-title span { font-size: 12px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); }

/* ── ABILITIES ── */
.abilities {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1px; background: var(--border);
  border: 1px solid var(--border); border-radius: 16px; overflow: hidden;
}
.ability { background: var(--bg2); padding: 28px 24px; transition: background 0.2s; }
.ability:hover { background: #141620; }
.ability-icon { font-size: 22px; margin-bottom: 14px; }
.ability-name { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.ability-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }

.divider { width: 100%; height: 1px; background: var(--border); max-width: 800px; margin: 0 auto; }

/* ── PERSONALITY ── */
.persona-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
@media (max-width: 560px) { .persona-grid { grid-template-columns: 1fr; } }
.persona-card { border: 1px solid var(--border); border-radius: 12px; padding: 24px; background: var(--bg2); }
.persona-label { font-size: 11px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: var(--accent); margin-bottom: 10px; }
.persona-text { font-size: 14px; color: #8892a4; line-height: 1.7; }
.persona-text strong { color: var(--text); font-weight: 500; }

/* ── QUOTE ── */
.quote-section { padding: 100px 24px; text-align: center; }
.quote { font-size: clamp(18px, 3.5vw, 26px); font-weight: 300; color: #6a7280; max-width: 600px; margin: 0 auto; line-height: 1.8; }
.quote em { color: var(--text); font-style: normal; font-weight: 400; }

/* ── FOOTER ── */
footer { text-align: center; padding: 32px 24px; border-top: 1px solid var(--border); font-size: 12px; color: #30363d; }
footer a { color: #404856; text-decoration: none; }
footer a:hover { color: var(--accent); }
</style>
</head>
<body>

