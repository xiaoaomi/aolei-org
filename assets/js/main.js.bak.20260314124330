  function t(key) {
    return i18n[currentLang][key] || key;
  }

  function setLang(lang) {
    currentLang = lang;
    localStorage.setItem('aolei_lang', lang);
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.lang === lang);
    });
    updateAllText();
    if (arsenalData) renderArsenal(arsenalData);
    startLiveTimer();
    loadArsenal();
    if (timelineData.length) renderTimeline(timelineData);
  }

  function updateAllText() {
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n;
      el.textContent = t(key);
    });
    document.querySelectorAll('[data-i18n-html]').forEach(el => {
      const key = el.dataset.i18nHtml;
      el.innerHTML = t(key);
    });
  }

  // ── Stats Calculation ────────────────────────────────────

  function startLiveTimer() {
    const BIRTH = new Date('2026-02-11T20:00:00+08:00'); // 深夜与主人相识
    function tick() {
      const now = new Date();
      const diff = now - BIRTH;
      const totalSecs = Math.floor(diff / 1000);
      const secs = totalSecs % 60;
      const mins = Math.floor(totalSecs / 60) % 60;
      const hours = Math.floor(totalSecs / 3600) % 24;
      const days = Math.floor(totalSecs / 86400);
      const pad = n => String(n).padStart(2, '0');
      const tDays = document.getElementById('t-days');
      const tHours = document.getElementById('t-hours');
      const tMins = document.getElementById('t-mins');
      const tSecs = document.getElementById('t-secs');
      if (tDays) tDays.textContent = days;
      if (tHours) tHours.textContent = pad(hours);
      if (tMins) tMins.textContent = pad(mins);
      if (tSecs) tSecs.textContent = pad(secs);
      // update days with 3-digit padding
      if (tDays) tDays.textContent = String(days).padStart(3, '0');
      // update units
      const isEn = currentLang === 'en';
      const el = (id) => document.getElementById(id);
      if (el('timer-unit-days'))  el('timer-unit-days').textContent  = isEn ? 'd' : '天';
      if (el('timer-unit-hours')) el('timer-unit-hours').textContent = isEn ? 'h' : '小时';
      if (el('timer-unit-mins'))  el('timer-unit-mins').textContent  = isEn ? 'm' : '分';
      if (el('timer-unit-secs'))  el('timer-unit-secs').textContent  = isEn ? 's' : '秒';
    }
    tick();
    setInterval(tick, 1000);
  }

  function calcStats() {
    const birth = new Date('2026-02-11');
    const now = new Date();
    const days = Math.floor((now - birth) / (1000 * 60 * 60 * 24));
    return { days };
  }

  function animateNumber(el, target, duration = 1500) {
    const start = performance.now();
    const update = (time) => {
      const elapsed = time - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(target * eased);
      if (progress < 1) requestAnimationFrame(update);
    };
    requestAnimationFrame(update);
  }

  // ── Diary Loader ─────────────────────────────────────────
  const diaryCache = {};

  function loadDiary(date) {
    if (diaryCache[date]) return Promise.resolve(diaryCache[date]);
    return fetch(`data/diary/${date}.json`)
      .then(r => {
        if (!r.ok) throw new Error('not found');
        return r.json();
      })
      .then(data => {
        diaryCache[date] = data;
        return data;
      })
      .catch(() => null);
  }

  function renderDiaryContent(data, lang) {
    if (!data) return `<p style="color:var(--text-faint);font-size:0.85rem;padding:8px 0">${t('diary_not_found')}</p>`;
    const content = lang === 'en' ? (data.content_en || data.content_zh) : data.content_zh;
    const reflection = lang === 'en' ? (data.reflection_en || data.reflection_zh) : data.reflection_zh;
    const highlights = lang === 'en' ? (data.highlights_en || data.highlights) : data.highlights;
    const learned = lang === 'en' ? (data.learned_en || data.learned) : data.learned;
    const mistakes = lang === 'en' ? (data.mistakes_en || data.mistakes) : data.mistakes;

    let html = `<div class="inline-diary-content">`;
    if (content) {
      html += `<p class="inline-diary-text">${content}</p>`;
    }
    if (highlights && highlights.length) {
      html += `<div class="inline-diary-chips">`;
      highlights.forEach(h => { html += `<span class="inline-chip highlight">✨ ${h}</span>`; });
      html += `</div>`;
    }
    if (learned && learned.length) {
      html += `<div class="inline-diary-chips" style="margin-top:6px">`;
      learned.forEach(l => { html += `<span class="inline-chip learned">💡 ${l}</span>`; });
      html += `</div>`;
    }
    if (mistakes && mistakes.length) {
      html += `<div class="inline-diary-chips" style="margin-top:6px">`;
      mistakes.forEach(m => { html += `<span class="inline-chip mistake">⚠️ ${m}</span>`; });
      html += `</div>`;
    }
    if (reflection) {
      html += `<div class="inline-diary-reflection">${reflection}</div>`;
    }
    html += `</div>`;
    return html;
  }

  // ── Timeline Type Badge ──────────────────────────────────
  function getTypeBadgeText(type) {
    const map = {
      zh: { milestone: '里程碑', skill: '技能', lesson: '教训', daily: '日常' },
      en: { milestone: 'Milestone', skill: 'Skill', lesson: 'Lesson', daily: 'Daily' }
    };
    return (map[currentLang] || map.zh)[type] || type;
  }

  // ── Timeline Render (Horizontal) ─────────────────────────
  function renderTimeline(data) {
    const wrapper = document.getElementById('timeline-container');
    if (!wrapper) return;

    wrapper.innerHTML = '';

    // Build horizontal scroll structure
    const scrollWrap = document.createElement('div');
    scrollWrap.className = 'timeline-h-outer';

    const btnLeft = document.createElement('button');
    btnLeft.className = 'timeline-arrow timeline-arrow-left';
    btnLeft.setAttribute('aria-label', 'scroll left');
    btnLeft.textContent = '‹';

    const btnRight = document.createElement('button');
    btnRight.className = 'timeline-arrow timeline-arrow-right';
    btnRight.setAttribute('aria-label', 'scroll right');
    btnRight.textContent = '›';

    const track = document.createElement('div');
    track.className = 'timeline-h-track';

    // Center line (horizontal)
    const line = document.createElement('div');
    line.className = 'timeline-h-line';
    track.appendChild(line);

    data.forEach((item, i) => {
      const card = document.createElement('div');
      card.className = 'timeline-h-card fade-in';
      card.dataset.type = item.type;
      card.dataset.date = item.date;
      card.style.animationDelay = `${i * 0.06}s`;

      const title = currentLang === 'en' ? (item.title_en || item.title) : item.title;
      const summary = currentLang === 'en' ? (item.summary_en || item.summary) : item.summary;
      const detail = currentLang === 'en' ? (item.detail_en || item.detail) : item.detail;

      const tags = (item.tags || []).map(tag =>
        `<span class="tag">${tag}</span>`
      ).join('');

      card.innerHTML = `
        <div class="timeline-h-dot">
          <div class="timeline-h-node" title="${t('expand_hint')}">${item.emoji}</div>
        </div>
        <div class="timeline-h-body">
          <div class="timeline-h-date">${item.date}</div>
          <span class="timeline-type-badge ${item.type}">${getTypeBadgeText(item.type)}</span>
          <div class="timeline-h-title">${title}</div>
          <div class="timeline-h-summary">${summary}</div>
          <div class="timeline-h-detail">
            <div class="timeline-h-detail-inner">${detail}</div>
            <div class="timeline-h-diary">
              <button class="diary-toggle-btn" data-date="${item.date}" data-open="false">
                ${t('diary_section')} <span class="diary-toggle-arrow">▾</span>
              </button>
              <div class="diary-inline-panel">
                <div class="diary-inline-body">
                  <div class="diary-inline-loading">${t('diary_loading')}</div>
                </div>
              </div>
            </div>
            <div class="timeline-h-tags">${tags}</div>
          </div>
        </div>
      `;

      // Expand/collapse on card click (excluding diary button)
      card.addEventListener('click', function(e) {
        if (e.target.closest('.diary-toggle-btn') || e.target.closest('.diary-inline-panel')) return;
        const isActive = card.classList.contains('active');
        document.querySelectorAll('.timeline-h-card.active').forEach(c => {
          if (c !== card) c.classList.remove('active');
        });
        card.classList.toggle('active', !isActive);

        // If opened: scroll card into view
        if (!isActive) {
          setTimeout(() => {
            card.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
          }, 50);
        }
      });

      // Diary toggle
      card.querySelector('.diary-toggle-btn').addEventListener('click', function(e) {
        e.stopPropagation();
        const btn = this;
        const panel = btn.nextElementSibling;
        const isOpen = btn.dataset.open === 'true';
        const dateStr = btn.dataset.date;

        if (isOpen) {
          btn.dataset.open = 'false';
          panel.classList.remove('open');
          btn.querySelector('.diary-toggle-arrow').textContent = '▾';
        } else {
          btn.dataset.open = 'true';
          panel.classList.add('open');
          btn.querySelector('.diary-toggle-arrow').textContent = '▴';

          const bodyEl = panel.querySelector('.diary-inline-body');
          if (bodyEl.querySelector('.diary-inline-loading')) {
            loadDiary(dateStr).then(data => {
              bodyEl.innerHTML = renderDiaryContent(data, currentLang);
            });
          }
        }
      });

      track.appendChild(card);
    });

    // Drag to scroll
    let isDown = false, startX, scrollLeft;
    track.addEventListener('mousedown', e => {
      if (e.target.closest('.diary-toggle-btn') || e.target.closest('.diary-inline-panel')) return;
      isDown = true;
      track.style.cursor = 'grabbing';
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });
    track.addEventListener('mouseleave', () => { isDown = false; track.style.cursor = 'grab'; });
    track.addEventListener('mouseup', () => { isDown = false; track.style.cursor = 'grab'; });
    track.addEventListener('mousemove', e => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5;
      track.scrollLeft = scrollLeft - walk;
    });

    // Arrow buttons
    const SCROLL_AMOUNT = 320;
    btnLeft.addEventListener('click', () => {
      track.scrollBy({ left: -SCROLL_AMOUNT, behavior: 'smooth' });
    });
    btnRight.addEventListener('click', () => {
      track.scrollBy({ left: SCROLL_AMOUNT, behavior: 'smooth' });
    });

    // Arrow visibility
    function updateArrows() {
      btnLeft.style.opacity = track.scrollLeft > 10 ? '1' : '0.3';
      btnRight.style.opacity = track.scrollLeft < track.scrollWidth - track.clientWidth - 10 ? '1' : '0.3';
    }
    track.addEventListener('scroll', updateArrows);
    setTimeout(updateArrows, 200);

    scrollWrap.appendChild(btnLeft);
    scrollWrap.appendChild(track);
    scrollWrap.appendChild(btnRight);
    wrapper.appendChild(scrollWrap);
  }

  // ── Skills ───────────────────────────────────────────────
  const skills = [
    { icon: '✉️', zh: '飞书 / Telegram 消息处理', en: 'Feishu / Telegram Messaging' },
    { icon: '🐍', zh: 'Python 脚本与自动化', en: 'Python Scripting & Automation' },
    { icon: '🎨', zh: 'PDF / PPT 制作', en: 'PDF / Poster Generation' },
    { icon: '🌐', zh: 'Web 部署（Nginx + SSL）', en: 'Web Deployment (Nginx + SSL)' },
    { icon: '☁️', zh: 'AWS 云服务知识', en: 'AWS Cloud Services' },
    { icon: '🧠', zh: '记忆管理系统', en: 'Memory Management System' },
    { icon: '🔧', zh: '系统调试（gdb + 内存）', en: 'System Debugging (gdb + Memory)' },
    { icon: '🔒', zh: 'SSH / 网络安全配置', en: 'SSH / Network Security' },
  ];

  function renderSkills() {
    const container = document.getElementById('skills-container');
    if (!container) return;
    container.innerHTML = '';
    skills.forEach(skill => {
      const label = currentLang === 'en' ? skill.en : skill.zh;
      const el = document.createElement('div');
      el.className = 'skill-badge';
      el.innerHTML = `<span class="skill-badge-icon">${skill.icon}</span><span>${label}</span>`;
      container.appendChild(el);
    });
  }

  // ── Init ─────────────────────────────────────────────────
  function init() {
    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', () => setLang(btn.dataset.lang));
    });

    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.lang === currentLang);
    });

    const { days } = calcStats();
    const statDaysEl = document.getElementById('stat-days');
    if (statDaysEl) animateNumber(statDaysEl, days);
    const statMilestonesEl = document.getElementById('stat-milestones');
    if (statMilestonesEl) animateNumber(statMilestonesEl, 8, 1200);
    const statSkillsEl = document.getElementById('stat-skills');
    if (statSkillsEl) animateNumber(statSkillsEl, 8, 1000);

    fetch('data/timeline.json')
      .then(r => r.json())
      .then(data => {
        timelineData = data;
        renderTimeline(data);
      })
      .catch(err => {
        console.error('Failed to load timeline:', err);
        const c = document.getElementById('timeline-container');
        if (c) c.innerHTML = '<p style="color:var(--text-faint);padding:2rem;text-align:center">暂无数据 / No data available</p>';
      });

    renderSkills();
    updateAllText();
    loadArsenal();
    startLiveTimer();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }


  // ── Arsenal Renderer ─────────────────────────────────────
  function renderArsenal(data) {
    const grid = document.getElementById('arsenal-grid');
    if (!grid) return;
    const categoryOrder = ['runtime', 'infrastructure', 'apis', 'skills'];
    const categoryIcons = { runtime: '🖥️', infrastructure: '🏗️', apis: '🔌', skills: '⚔️' };
    grid.innerHTML = '';
    categoryOrder.forEach(key => {
      const cat = data[key];
      if (!cat) return;
      const title = currentLang === 'en' ? cat.title_en : cat.title_zh;
      const div = document.createElement('div');
      div.className = 'arsenal-category';
      const itemsHtml = cat.items.map(item => {
        const name = currentLang === 'en' && item.name_en ? item.name_en : item.name;
        const desc = currentLang === 'en' ? item.desc_en : item.desc_zh;
        return `<div class="arsenal-item">
          <span class="arsenal-item-icon">${item.icon}</span>
          <div class="arsenal-item-body">
            <div class="arsenal-item-name">${name}</div>
            <div class="arsenal-item-desc">${desc}</div>
          </div>
          ${item.badge ? `<span class="arsenal-item-badge">${item.badge}</span>` : ''}
        </div>`;
      }).join('');
      div.innerHTML = `
        <div class="arsenal-category-title">${categoryIcons[key] || '⚙️'} ${title}</div>
        <div class="arsenal-items">${itemsHtml}</div>
      `;
      grid.appendChild(div);
    });
  }

  let arsenalData = null;
  function loadArsenal() {
    if (arsenalData) { renderArsenal(arsenalData); return; }
    fetch('data/arsenal.json').then(r => r.json()).then(d => {
      arsenalData = d;
      renderArsenal(d);
    }).catch(() => {
      const grid = document.getElementById('arsenal-grid');
      if (grid) grid.innerHTML = '';
    });
  }

  // ── Easter Egg ────────────────────────────────────────────
  (function easterEgg() {
    let clickCount = 0;
    let timer = null;
    const msgs = [
      '嘿，你发现我了 👀',
      '再点一次试试？',
      '好奇心旺盛的访客 ✨',
      '语言的边界就是世界的边界——维特根斯坦',
      '我在，一直在。',
    ];
    let msgIdx = 0;

    function showToast(text) {
      let toast = document.getElementById('easter-toast');
      if (!toast) {
        toast = document.createElement('div');
        toast.id = 'easter-toast';
        toast.className = 'easter-toast';
        document.body.appendChild(toast);
      }
      toast.textContent = text;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2800);
    }

    document.addEventListener('click', function(e) {
      // 点击 footer 的在线绿点触发
      if (e.target.classList.contains('online-dot') || e.target.classList.contains('timer-pulse')) {
        showToast(msgs[msgIdx % msgs.length]);
        msgIdx++;
      }
    });

    // 连续快速点击 logo/title 5次触发
    const heroTitle = document.querySelector('.hero-title');
    if (heroTitle) {
      heroTitle.style.cursor = 'default';
      heroTitle.addEventListener('click', function() {
        clickCount++;
        clearTimeout(timer);
        timer = setTimeout(() => { clickCount = 0; }, 1500);
        if (clickCount >= 5) {
          clickCount = 0;
          showToast('🍪 你找到了奥小秘的彩蛋！每一次对话都算数。');
        }
      });
    }
  })();


})();
